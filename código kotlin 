// Modelo de datos para cada "píxel" ASCII
data class AsciiCell(
    val char: String = " ",
    val color: Color = Color.Gray
)

class MainActivity : ComponentActivity() {
    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContent {
            CanvasSonoroTheme {
                Surface(modifier = Modifier.fillMaxSize(), color = Color.Black) {
                    CanvasSonoroScreen()
                }
            }
        }
    }
}

@Composable
fun CanvasSonoroScreen() {
    val rows = 25
    val cols = 20
    
    // Estado global del lienzo (tu array CANVAS en Bash)
    val canvasState = remember { 
        mutableStateListOf<AsciiCell>().apply { 
            repeat(rows * cols) { add(AsciiCell()) } 
        } 
    }

    var selectedColor by remember { mutableStateOf(Color.Green) }
    var selectedChar by remember { mutableStateOf("█") }

    Column(modifier = Modifier.fillMaxSize()) {
        // Cabecera estilo Terminal
        Text(
            text = "╔════ CANVAS SONORO ════╗",
            color = Color(0xFFFFD700), // Gold
            fontFamily = FontFamily.Monospace,
            modifier = Modifier.padding(16.dp).align(Alignment.CenterHorizontally)
        )

        // El Canvas (Grid interactiva)
        Box(
            modifier = Modifier
                .weight(1f)
                .padding(8.dp)
                .aspectRatio(cols.toFloat() / rows.toFloat())
                .background(Color(0xFF050505))
                .pointerInput(Unit) {
                    detectDragGestures { change, _ ->
                        val x = change.position.x
                        val y = change.position.y
                        
                        // Calcular qué celda se está tocando
                        val cellWidth = size.width / cols
                        val cellHeight = size.height / rows
                        val col = (x / cellWidth).toInt().coerceIn(0, cols - 1)
                        val row = (y / cellHeight).toInt().coerceIn(0, rows - 1)
                        val index = row * cols + col
                        
                        // Actualizar la celda "pintándola"
                        canvasState[index] = AsciiCell(selectedChar, selectedColor)
                    }
                }
        ) {
            LazyVerticalGrid(
                columns = GridCells.Fixed(cols),
                userScrollEnabled = false // Desactivamos scroll para poder dibujar
            ) {
                items(canvasState.size) { index ->
                    Text(
                        text = canvasState[index].char,
                        color = canvasState[index].color,
                        fontSize = 14.sp,
                        fontFamily = FontFamily.Monospace,
                        modifier = Modifier.height(20.dp), // Ajuste visual de la celda
                        softWrap = false
                    )
                }
            }
        }

        // Panel de Controles (Colores y Caracteres)
        ControlsPanel(
            onColorSelect = { selectedColor = it },
            onCharSelect = { selectedChar = it },
            onClear = { 
                for (i in canvasState.indices) canvasState[i] = AsciiCell() 
            }
        )
    }
}

@Composable
fun ControlsPanel(onColorSelect: (Color) -> Unit, onCharSelect: (String) -> Unit, onClear: () -> Unit) {
    Column(modifier = Modifier.background(Color(0xFF1A1A1A)).padding(8.dp)) {
        // Selector de Caracteres
        Row(Modifier.fillMaxWidth(), horizontalArrangement = Arrangement.SpaceEvenly) {
            listOf("█", "░", "★", "●", "◆").forEach { char ->
                Button(onClick = { onCharSelect(char) }, colors = ButtonDefaults.buttonColors(containerColor = Color.DarkGray)) {
                    Text(char)
                }
            }
        }
        
        Spacer(modifier = Modifier.height(8.dp))

        // Selector de Colores (Los mismos de tu Bash)
        Row(Modifier.fillMaxWidth(), horizontalArrangement = Arrangement.SpaceEvenly) {
            val colors = listOf(Color.Red, Color.Green, Color.Yellow, Color.Cyan, Color.Magenta, Color.White)
            colors.forEach { color ->
                IconButton(onClick = { onColorSelect(color) }) {
                    Box(modifier = Modifier.size(24.dp).background(color))
                }
            }
            Button(onClick = onClear, colors = ButtonDefaults.buttonColors(containerColor = Color.Red)) {
                Text("Limpiar", fontSize = 10.sp)
            }
        }
    }
}

